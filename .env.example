# Runtime environment
ASPNETCORE_ENVIRONMENT=Development

# Database
ConnectionStrings__Default=Data Source=database/meal.dev.db

# AI - Local provider (Ollama)
AI__Provider=Ollama
AI__BaseUrl=http://localhost:11434
AI__Model=llama3.2
AI__TimeoutSeconds=30
AI__RetryCount=1

# Optional app settings
App__AllowedOrigins=http://localhost:5000;http://localhost:5001
