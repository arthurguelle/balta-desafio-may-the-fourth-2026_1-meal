@page "/"
@using System.Net.Http
@using System.Net.Http.Json
@using System.Text.Json
@inject IHttpClientFactory HttpClientFactory

<PageTitle>Meal Mission Control</PageTitle>

<section class="mission-shell">
	<header class="mission-header">
		<p class="label">MISSION PANEL</p>
		<h1>Meal Mission Control</h1>
		<p class="subtitle">Cruze ingredientes e tempo livre para gerar uma receita dentro da sua janela de agenda.</p>
	</header>

	<div class="status-row">
		<span class="status-chip @(aiHealthy == true ? "ok" : "alert")">
			@AiStatusLabel
		</span>
	</div>

	<EditForm Model="request" OnValidSubmit="SuggestRecipeAsync" class="mission-form">
		<div class="field">
			<label for="ingredients">Ingredientes disponiveis</label>
			<InputTextArea id="ingredients" @bind-Value="request.Ingredients" class="mission-input" rows="4" />
		</div>

		<div class="field">
			<label for="minutes">Tempo livre (minutos)</label>
			<InputNumber id="minutes" @bind-Value="request.AvailableMinutes" class="mission-input" min="1" />
		</div>

		<button type="submit" class="launch-button" disabled="@isLoading">
			@(isLoading ? "Calculando rota culinaria..." : "Gerar receita")
		</button>
	</EditForm>

	@if (!string.IsNullOrWhiteSpace(errorMessage))
	{
		<div class="feedback error">@errorMessage</div>
	}

	@if (!string.IsNullOrWhiteSpace(recipeSuggestion))
	{
		<article class="recipe-output">
			<h2>Receita sugerida</h2>
			<pre>@recipeSuggestion</pre>
		</article>
	}
</section>

@code {
	private readonly SuggestRecipeRequest request = new()
	{
		Ingredients = "frango, arroz, tomate",
		AvailableMinutes = 30
	};

	private bool isLoading;
	private bool? aiHealthy;
	private string? recipeSuggestion;
	private string? errorMessage;

	private string AiStatusLabel => aiHealthy == true
		? "IA local online"
		: "IA local offline";

	protected override async Task OnInitializedAsync()
	{
		var client = HttpClientFactory.CreateClient("MealApi");

		try
		{
			var health = await client.GetFromJsonAsync<AiHealthResponse>("/health/ai");
			aiHealthy = string.Equals(health?.Status, "healthy", StringComparison.OrdinalIgnoreCase);
		}
		catch
		{
			aiHealthy = false;
		}
	}

	private async Task SuggestRecipeAsync()
	{
		if (request.AvailableMinutes <= 0)
		{
			errorMessage = "Preencha um tempo maior que zero.";
			return;
		}

		if (string.IsNullOrWhiteSpace(request.Ingredients))
		{
			errorMessage = "Informe os ingredientes disponiveis.";
			return;
		}

		isLoading = true;
		recipeSuggestion = null;
		errorMessage = null;

		try
		{
			var client = HttpClientFactory.CreateClient("MealApi");
			using var response = await client.PostAsJsonAsync("/recipes/suggest", request);

			if (response.IsSuccessStatusCode)
			{
				var success = await response.Content.ReadFromJsonAsync<SuggestRecipeResponse>();
				recipeSuggestion = success?.Recipe ?? "A API respondeu sem conteudo de receita.";
				return;
			}

			var rawError = await response.Content.ReadAsStringAsync();
			errorMessage = TryReadProblemDetail(rawError)
				?? "Nao foi possivel gerar receita agora. Verifique se a IA local esta ativa em localhost:11434.";
		}
		catch (Exception ex)
		{
			errorMessage = $"Falha na comunicacao com a API: {ex.Message}";
		}
		finally
		{
			isLoading = false;
		}
	}

	private static string? TryReadProblemDetail(string raw)
	{
		try
		{
			var problem = JsonSerializer.Deserialize<ProblemDetailsLike>(raw);
			if (!string.IsNullOrWhiteSpace(problem?.Detail))
				return problem.Detail;

			return problem?.Title;
		}
		catch
		{
			return null;
		}
	}

	private sealed class SuggestRecipeRequest
	{
		public string? Ingredients { get; set; } = string.Empty;
		public int AvailableMinutes { get; set; }
	}

	private sealed record SuggestRecipeResponse(string Recipe);
	private sealed record AiHealthResponse(string Service, string Status);
	private sealed record ProblemDetailsLike(string? Title, string? Detail);
}
